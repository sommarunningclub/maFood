# URL canônica usada nos links enviados por e-mail
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase — a URL não é secreta, mas o cliente atual é server-side
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co

# Somente servidor. Esta chave ignora RLS; nunca use NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Assina as três famílias de cookies JWT. Use pelo menos 32 bytes aleatórios.
PDV_SESSION_SECRET=

# Asaas: sandbox local por padrão
ASAAS_BASE_URL=https://api-sandbox.asaas.com/v3
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=

# Simulação exige opt-in explícito e deve permanecer false em produção.
ASAAS_ALLOW_SIMULATED=false

# Envio de links de pagamento por e-mail (opcional)
RESEND_API_KEY=
VIP_EMAIL_FROM="maFood <no-reply@example.com>"
